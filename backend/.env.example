# =============================================================================
# Backend environment variables
# =============================================================================
# Copy this file to .env before starting the application:
#
#   Windows:       copy .env.example .env
#   Linux / macOS: cp .env.example .env
#
# Never commit .env — it may contain real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Application server
# -----------------------------------------------------------------------------

# Host interface the API binds to inside the container/process.
# Default is fine for Docker and local runs.
# Required: No | Default: 0.0.0.0
APP_HOST=0.0.0.0

# Port the API listens on.
# Required: No | Default: 8000 | Example: 8000
APP_PORT=8000

# -----------------------------------------------------------------------------
# Verification Engine V1
# Credentials and timeouts for the first verification provider adapter.
# -----------------------------------------------------------------------------

# API key issued by Verification Engine V1.
# Required: Yes (when using engine v1) | Example: sk-xxxxxxxx
TRUTHSCAN_API_KEY=your-engine-v1-api-key-here

# Base URL for Verification Engine V1 HTTP API.
# Required: Yes (when using engine v1) | Example: https://api.example-v1.com
TRUTHSCAN_BASE_URL=

# Request timeout in seconds for Verification Engine V1 calls.
# Required: No | Default: 60 | Example: 60
TRUTHSCAN_TIMEOUT=60

# -----------------------------------------------------------------------------
# Verification Engine V2
# Credentials and timeouts for the second verification provider adapter.
# -----------------------------------------------------------------------------

# API key issued by Verification Engine V2.
# Required: Yes (when using engine v2) | Example: pw-xxxxxxxx
PAPERWORK_API_KEY=your-engine-v2-api-key-here

# Base URL for Verification Engine V2 HTTP API.
# Required: Yes (when using engine v2) | Example: https://api.example-v2.com
PAPERWORK_BASE_URL=

# Request timeout in seconds for Verification Engine V2 calls.
# Required: No | Default: 300 | Example: 300
PAPERWORK_TIMEOUT=300

# -----------------------------------------------------------------------------
# Azure OpenAI (optional AI analysis)
# Used by the AI analysis adapter when enabled.
# -----------------------------------------------------------------------------

# Azure OpenAI API key.
# Required: No (adapter is optional) | Example: your-azure-openai-key
AZURE_OPENAI_API_KEY=

# Azure OpenAI endpoint URL.
# Required: No | Example: https://your-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI deployment (model) name.
# Required: No | Example: gpt-4o
AZURE_OPENAI_DEPLOYMENT=
