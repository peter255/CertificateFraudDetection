# =============================================================================
# Frontend environment variables
# =============================================================================
# Copy this file to .env before starting the application:
#
#   Windows:       copy .env.example .env
#   Linux / macOS: cp .env.example .env
#
# Never commit .env — keep secrets and local overrides out of version control.
# =============================================================================

# Public backend URL as seen from the developer’s browser.
# Used as documentation and as a fallback Vite proxy target for local (non-Docker) runs.
# In Docker Compose, the proxy target is overridden to the backend service name.
# Required: No | Default (proxy): http://localhost:8000 | Example: http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# Active verification engine.
# Change this single value to switch engines — the UI stays vendor-independent.
#   v1 → Verification Engine V1  (POST /api/v1/vendors/v1/verify)
#   v2 → Verification Engine V2  (POST /api/v1/vendors/v2/verify)
# Required: Yes | Allowed: v1 | v2 | Example: v2
VITE_VERIFICATION_ENGINE=v2
